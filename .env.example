# Runtime profile
# local/dev: APP_ENV=local
# prod: APP_ENV=prod
APP_ENV=local
NODE_ENV=development

# App runtime
PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Database
# Host port used by docker-compose postgres mapping (container is always 5432)
POSTGRES_PORT=5433
# local/dev default (docker-compose postgres service)
DATABASE_URL=postgresql://relagraph:relagraph@localhost:5433/relagraph

# prod example (set in deployment secrets, do not commit real values)
# DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>?sslmode=require
